# ============================================================
# Variables de Entorno — Proyecto FHIR Salud Digital (C2)
# Copiar este archivo como .env y ajustar los valores
# ============================================================

# Base de datos PostgreSQL (Render o local)
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

# JWT
JWT_SECRET=super-secret-jwt-key-cambiar-en-produccion-2026

# API Keys (Doble autenticación)
ACCESS_KEY=master-access-key
ADMIN_PERM_KEY=admin-permission
MEDICO_PERM_KEY=medico-permission
PACIENTE_PERM_KEY=paciente-permission

# Encriptación (Fernet — solo si se usa)
FERNET_KEY=

# CORS (separar con coma si hay más de un origen)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8501

# Orquestador
MAX_WORKERS=4
